---
layout: layouts/base.njk
---
<section class="relative h-[75vh]">
  <img src="{{ image }}" alt="" class="object-cover w-full h-full">
  <div class="absolute inset-0 bg-black bg-opacity-30 flex items-center justify-center">
    <h1 class="text-white text-4xl md:text-5xl font-semibold text-center px-4">
      {{ title }}
    </h1>
  </div>
</section>

{# body section #}
<section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-8 px-6 py-12">
  <!-- Left column: Contributor Credits -->
  <aside class="md:col-span-1 text-sm space-y-4 leading-tight">
    <div>
      <h2 class="font-semibold uppercase text-xs tracking-widest text-gray-500 mb-1">Videographers</h2>
      <p>{{ video_1_byline }}</p>
      <p>{{ video_2_byline }}</p>
    </div>

    <div>
      <h2 class="font-semibold uppercase text-xs tracking-widest text-gray-500 mb-1">Photographer</h2>
      <p>{{ photo_byline }}</p>
    </div>

    <div>
      <h2 class="font-semibold uppercase text-xs tracking-widest text-gray-500 mb-1">Reporter</h2>
      <p>{{ reporter_byline }}</p>
    </div>

    <div>
      <h2 class="font-semibold uppercase text-xs tracking-widest text-gray-500 mb-1">Interactive</h2>
      <p>{{ interactive_1_byline }}</p>
      <p>{{ interactive_2_byline }}</p>
    </div>

    <div>
      <h2 class="font-semibold uppercase text-xs tracking-widest text-gray-500 mb-1">UCA Contributors</h2>
      <p>{{ uca_contributor_1_byline }}</p>
      <p>{{ uca_contributor_2_byline }}</p>
    </div>
  </aside>

  <!-- Right column: Story Body -->
  <div class="md:col-span-3 prose prose-lg max-w-none">
    {{ body_copy | renderContent("njk") | markdown | safe }}
  </div>
</section>


<article class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-4">{{ title }}</h1>
  <p class="mb-2">By {{ reporter_byline }}</p>
  {# <img src="{{ image }}" alt="{{ title }}" class="mb-6 w-full h-auto rounded"> #}

  <div class="markdown-content">
    {{ body_copy | renderContent("njk") | markdown | safe }}
  </div>
</article>